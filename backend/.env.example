# ============================================
# PuddingClaw 后端环境变量配置
# ============================================

# DeepSeek API 配置（主要 LLM）
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# OpenAI API 配置（用于 Embedding 和备用 LLM）
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small

# 服务器配置
HOST=0.0.0.0
PORT=8002

# 智慧芽 MCP 配置（专利检索）
# 从 https://open.zhihuiya.com/devportal/api-keys 获取 MCP Key，格式 sk-xxxxxxxxxxxx
ZHIHUIYA_MCP_API_KEY=your_zhihuiya_mcp_key_here

# 可选基础设施地址
# MinerU 本机运行时：http://host.docker.internal:8002
# Higress Docker full profile 时 backend 容器内：http://higress:8080/v1
# MINERU_URL=http://host.docker.internal:8002
# AI_GATEWAY_URL=http://host.docker.internal:8080/v1

# 其他配置
HTTP_TIMEOUT_SECONDS=30
