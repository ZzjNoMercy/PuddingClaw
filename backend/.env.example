# ============================================
# PuddingClaw 后端环境变量配置
# ============================================

# DeepSeek API 配置（主要 LLM）
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# OpenAI API 配置（用于 Embedding 和备用 LLM）
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4

# 服务器配置
HOST=0.0.0.0
PORT=8888

# 搜索引擎配置
TAVILY_API_KEY=your_tavily_api_key_here

# 智慧芽 MCP 配置（专利检索）
# 从 https://open.zhihuiya.com/devportal/api-keys 获取 MCP Key，格式 sk-xxxxxxxxxxxx
ZHIHUIYA_MCP_API_KEY=your_zhihuiya_mcp_key_here

# 本地基础设施地址
# frontend/backend 在本机运行；Higress/Milvus 由 docker-compose.infra.yml 提供；
# MinerU 在本机运行，不进入 Docker。
AI_GATEWAY_URL=http://localhost:8080/v1
MINERU_URL=http://localhost:8002
MILVUS_URL=http://localhost:19530

# 其他配置
HTTP_TIMEOUT_SECONDS=30
